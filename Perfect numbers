# %% :::::::::::::::::::::::::::::::::::::::::::: FUNCTION 2 ::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::: #
# returns the list of the first n-th perfect numbers
def n_perfect_numbers(n_values):
    time_start = time.time()
    perfect_numbers = []
    
    n = 1
    while True:
        n += 1
        
        mersenne = 2**n-1 # calculate Mersenne's number
        if not isprime(mersenne): continue # avoid useless computation
        
        perfect_number = 2**(n-1)*mersenne # valid <=> Mersenne's number is prime
        perfect_numbers.append(perfect_number)
        
        if len(perfect_numbers) >= n_values: break # ends the loop

    print(f"execution time: {time.time()-time_start}sec.\n\n")
    return perfect_numbers

    
    
